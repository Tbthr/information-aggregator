generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Content {
  id               String   @id @default(cuid())
  kind             String
  sourceId         String

  title            String?
  body             String?  @db.Text
  url              String
  authorLabel      String?
  publishedAt      DateTime @db.Timestamptz
  fetchedAt        DateTime @default(now()) @db.Timestamptz

  engagementScore  Int?
  qualityScore     Float?

  topicIds         String[]
  topicScoresJson  String?  @db.Text
  metadataJson     String?  @db.Text

  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt    @db.Timestamptz

  @@unique([url])
  @@index([sourceId])
  @@index([fetchedAt])
  @@index([publishedAt])
}

model DailyOverview {
  id            String   @id @default(cuid())
  date          String   @unique
  dayLabel      String
  topicCount    Int      @default(0)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  errorMessage  String?
  errorSteps    Json?

  @@index([topicCount])

  topics        DigestTopic[]
}

model DigestTopic {
  id          String        @id @default(cuid())
  dailyId     String
  daily       DailyOverview @relation(fields: [dailyId], references: [id], onDelete: Cascade)

  order       Int
  title       String
  summary     String
  contentIds  String[]
  createdAt   DateTime      @default(now()) @db.Timestamptz

  @@index([dailyId])
}

model DailyReportConfig {
  id                 String   @id @default("default")

  topicIds           String[]
  maxItems           Int      @default(50)
  minScore           Int      @default(0)

  keywordBlacklist   String[]
  filterPrompt       String?
  topicPrompt        String
  topicSummaryPrompt String

  kindPreferences    String?  @db.Text

  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz
}

model Source {
  id               String   @id @default(cuid())
  kind             String
  name             String
  url              String
  description      String?
  enabled          Boolean  @default(true)
  configJson       String?  @db.Text

  priority         Int      @default(0)
  defaultTopicIds  String[] @default([])
  authRef          String?

  health           SourceHealth?

  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt    @db.Timestamptz
}

model SourceHealth {
  id                  String    @id @default(cuid())
  sourceId            String    @unique
  lastSuccessAt       DateTime? @db.Timestamptz
  lastFailureAt       DateTime? @db.Timestamptz
  lastError           String?
  consecutiveFailures Int       @default(0)
  updatedAt           DateTime  @db.Timestamptz
  source              Source    @relation(fields: [sourceId], references: [id])
}

model Topic {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  enabled       Boolean  @default(true)

  includeRules  String[] @default([])
  excludeRules  String[] @default([])
  scoreBoost    Float    @default(1.0)
  displayOrder  Int      @default(0)
  maxItems      Int      @default(10)

  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt    @db.Timestamptz
}

model WeeklyReport {
  id            String   @id @default(cuid())
  weekNumber    String   @unique
  editorial     String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  errorMessage  String?
  errorSteps    Json?

  picks         WeeklyPick[]
}

model WeeklyPick {
  id          String        @id @default(cuid())
  weeklyId    String
  weekly      WeeklyReport  @relation(fields: [weeklyId], references: [id], onDelete: Cascade)

  order       Int
  contentId   String?
  reason      String
  createdAt   DateTime      @default(now()) @db.Timestamptz

  @@index([weeklyId])
}

model WeeklyReportConfig {
  id                 String   @id @default("default")

  days               Int      @default(7)

  editorialPrompt    String?
  pickReasonPrompt   String?

  pickCount          Int      @default(6)

  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz
}

model XPageConfig {
  tab             String   @unique
  enabled         Boolean  @default(true)
  birdMode        String
  count           Int      @default(20)
  fetchAll        Boolean  @default(false)
  maxPages        Int?
  listsJson       String?  @db.Text
  filterPrompt    String?  @db.Text
  enrichEnabled   Boolean  @default(true)
  enrichScoring   Boolean  @default(true)
  enrichKeyPoints Boolean  @default(true)
  enrichTagging   Boolean  @default(true)
  timeWindow      String   @default("week")
  sortOrder       String   @default("ranked")
  updatedAt       DateTime @updatedAt @db.Timestamptz
}
