generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AuthConfig {
  sourceId   String   @id
  configJson String
  updatedAt  DateTime
  source     Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id           String   @id @default(cuid())
  itemId       String   @unique
  bookmarkedAt DateTime @default(now())
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model CustomView {
  id             String           @id @default(cuid())
  name           String
  icon           String
  description    String?
  createdAt      DateTime         @default(now())
  filterJson     String?
  updatedAt      DateTime
  order          Int              @default(0)
  customViewPacks CustomViewPack[]
}

model CustomViewPack {
  id         String     @id @default(cuid())
  viewId     String
  packId     String
  pack       Pack       @relation(fields: [packId], references: [id], onDelete: Cascade)
  view       CustomView @relation(fields: [viewId], references: [id], onDelete: Cascade)

  @@unique([viewId, packId])
  @@index([viewId])
}

model DailyOverview {
  id        String   @id @default(cuid())
  date      String   @unique
  dayLabel  String
  summary   String
  itemIds   String[]
  createdAt DateTime @default(now())
}

model DailyReportConfig {
  id                  String   @id @default("default")
  packs               String   @default("all")
  maxItems            Int      @default(20)
  sort                String   @default("ranked")
  enableOverview      Boolean  @default(true)
  newsFlashesEnabled  Boolean  @default(true)
  newsFlashesMaxCount Int      @default(12)
  updatedAt           DateTime
}

model Item {
  id           String   @id @default(cuid())
  title        String
  url          String
  sourceId     String
  sourceName   String
  sourceType   String
  publishedAt  DateTime?
  fetchedAt    DateTime @default(now())
  author       String?
  summary      String?  @db.Text
  bullets      String[]
  content      String?  @db.Text
  imageUrl     String?
  categories   String[]
  score        Float    @default(5.0)
  metadataJson String?  @db.Text

  source       Source        @relation(fields: [sourceId], references: [id])
  bookmarks    Bookmark[]
  newsFlashes  NewsFlash[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([url])
  @@index([sourceId])
  @@index([fetchedAt])
  @@index([score])
}

model NewsFlash {
  id        String   @id @default(cuid())
  time      String
  text      String
  itemId    String?
  dailyDate String?
  createdAt DateTime @default(now())
  item      Item?    @relation(fields: [itemId], references: [id])
}

model Pack {
  id          String   @id @default(cuid())
  name        String
  description String?

  sources     Source[]
  customViews CustomViewPack[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProviderConfig {
  id          String   @id @default(cuid())
  provider    String   @unique
  model       String
  baseUrl     String?
  apiKeyRef   String?
  extraConfig String?
  updatedAt   DateTime
}

model SchedulerJob {
  id          String    @id @default(cuid())
  name        String
  cron        String
  description String?
  enabled     Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  updatedAt   DateTime
}

model Settings {
  id            String   @id @default("default")
  maxRetries    Int      @default(3)
  initialDelay  Int      @default(1000)
  maxDelay      Int      @default(30000)
  backoffFactor Float    @default(2.0)
  updatedAt     DateTime
  batchSize     Int      @default(3)
  concurrency   Int      @default(1)
  provider      String   @default("anthropic")
}

model Source {
  id          String   @id @default(cuid())
  type        String
  name        String
  url         String
  description String?
  enabled     Boolean  @default(true)
  configJson  String?  @db.Text
  packId      String?

  pack        Pack?    @relation(fields: [packId], references: [id])
  items       Item[]
  health      SourceHealth?
  authConfig  AuthConfig?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([packId, url])
  @@index([packId])
}

model SourceHealth {
  id                  String    @id @default(cuid())
  sourceId            String    @unique
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  lastError           String?
  consecutiveFailures Int       @default(0)
  updatedAt           DateTime
  source              Source    @relation(fields: [sourceId], references: [id])
}

model TimelineEvent {
  id             String       @id @default(cuid())
  weeklyReportId String
  date           String
  dayLabel       String
  title          String
  summary        String
  order          Int          @default(0)
  itemIds        String[]
  weeklyReport   WeeklyReport @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)

  @@index([weeklyReportId])
}

model WeeklyReport {
  id            String          @id @default(cuid())
  weekNumber    String          @unique
  headline      String
  subheadline   String?
  editorial     String?
  createdAt     DateTime        @default(now())
  timelineEvents TimelineEvent[]
}

model WeeklyReportConfig {
  id                String   @id @default("default")
  days              Int      @default(7)
  maxTimelineEvents Int      @default(10)
  maxDeepDives      Int      @default(5)
  enableEditorial   Boolean  @default(true)
  updatedAt         DateTime
}
