generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Bookmark {
  id           String   @id @default(cuid())
  itemId       String   @unique
  contentId    String?  // NEW: unified bookmark target (additive for migration)
  bookmarkedAt DateTime @default(now()) @db.Timestamptz
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Content {
  id               String   @id @default(cuid())
  kind             String   // "article" | "tweet" | "video" | etc.
  sourceId         String

  title            String?
  body             String?  @db.Text
  url              String
  authorLabel      String?
  publishedAt      DateTime               @db.Timestamptz
  fetchedAt        DateTime @default(now()) @db.Timestamptz

  engagementScore  Int?     // likes, retweets, replies combined
  qualityScore    Float?   // AI-computed quality

  topicIds         String[] // associated Topic ids
  topicScoresJson  String?  @db.Text // JSON: { topicId: score }
  metadataJson     String?  @db.Text

  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt    @db.Timestamptz

  @@unique([url])
  @@index([sourceId])
  @@index([fetchedAt])
  @@index([publishedAt])
}

model CustomView {
  id             String           @id @default(cuid())
  name           String
  icon           String
  description    String?
  createdAt      DateTime         @default(now()) @db.Timestamptz
  filterJson     String?
  updatedAt      DateTime         @db.Timestamptz
  order          Int              @default(0)
  customViewPacks CustomViewPack[]
}

model CustomViewPack {
  id         String     @id @default(cuid())
  viewId     String
  packId     String
  pack       Pack       @relation(fields: [packId], references: [id], onDelete: Cascade)
  view       CustomView @relation(fields: [viewId], references: [id], onDelete: Cascade)

  @@unique([viewId, packId])
  @@index([viewId])
}

model DailyOverview {
  id            String   @id @default(cuid())
  date          String   @unique
  dayLabel      String
  topicCount    Int      @default(0)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  errorMessage  String?
  errorSteps    Json?

  @@index([topicCount])

  topics        DigestTopic[]
}

model DigestTopic {
  id          String        @id @default(cuid())
  dailyId     String
  daily       DailyOverview @relation(fields: [dailyId], references: [id], onDelete: Cascade)

  order       Int
  title       String
  summary     String
  itemIds     String[]  // LEGACY: Kept for migration
  tweetIds    String[]  // LEGACY: Kept for migration
  contentIds  String[]  // NEW: unified content references
  createdAt   DateTime      @default(now()) @db.Timestamptz

  @@index([dailyId])
}

model DailyReportConfig {
  id                 String   @id @default("default")

  packs              String[]  // LEGACY: Kept for migration
  topicIds           String[]  // NEW: topic-based config (additive for migration)
  maxItems           Int      @default(50)
  minScore           Int      @default(0)

  keywordBlacklist   String[]
  filterPrompt       String?
  topicPrompt        String
  topicSummaryPrompt String

  // Daily-config kind preferences for article vs tweet base scoring (additive for migration)
  // Stored as JSON: { articles?: number, tweets?: number }
  kindPreferences    String?  @db.Text

  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz
}

model Item {
  id           String   @id @default(cuid())
  title        String
  url          String
  sourceId     String
  sourceName   String
  sourceType   String
  publishedAt  DateTime?              @db.Timestamptz
  fetchedAt    DateTime @default(now()) @db.Timestamptz
  author       String?
  summary      String?  @db.Text
  content      String?  @db.Text
  metadataJson String?  @db.Text

  // Pack reference (additive for migration - allows items to be associated with packs)
  packId       String?
  pack         Pack?    @relation(fields: [packId], references: [id])

  source       Source        @relation(fields: [sourceId], references: [id])
  bookmarks    Bookmark[]

  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt    @db.Timestamptz

  @@unique([url])
  @@index([sourceId])
  @@index([fetchedAt])
  @@index([publishedAt])
  @@index([packId])
}

model Pack {
  id          String   @id @default(cuid())
  name        String
  description String?

  // Pack-level filter config (additive for migration)
  mustInclude String[] @default([])  // Required keywords for items in this pack
  exclude     String[] @default([])  // Excluded keywords for items in this pack

  sources     Source[]
  customViews CustomViewPack[]
  items       Item[]    // Reverse relation for items in this pack

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt    @db.Timestamptz
}

model Source {
  id               String   @id @default(cuid())
  kind             String   // RENAMED: was "type", unified source kind (rss, x, youtube, etc.)
  name             String
  url              String
  description      String?
  enabled          Boolean  @default(true)
  configJson       String?  @db.Text
  packId           String?

  // NEW fields for topic unification
  priority         Int      @default(0)  // Higher = more important source
  defaultTopicIds  String[] @default([]) // Default topics to assign
  authRef          String?  // Authentication reference (API key name, OAuth token id, etc.)

  pack             Pack?    @relation(fields: [packId], references: [id])
  items            Item[]
  health           SourceHealth?

  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt    @db.Timestamptz

  @@unique([packId, url])
  @@index([packId])
}

model SourceHealth {
  id                  String    @id @default(cuid())
  sourceId            String    @unique
  lastSuccessAt       DateTime? @db.Timestamptz
  lastFailureAt       DateTime? @db.Timestamptz
  lastError           String?
  consecutiveFailures Int       @default(0)
  updatedAt           DateTime  @db.Timestamptz
  source              Source    @relation(fields: [sourceId], references: [id])
}

model Topic {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  enabled       Boolean  @default(true) // 栏目总开关；关闭后既不参与分类，也不参与展示

  // NEW: topic matching rules
  includeRules  String[] @default([])  // Keywords/patterns that MUST match
  excludeRules  String[] @default([])  // Keywords/patterns that MUST NOT match
  scoreBoost    Float    @default(1.0) // Multiplier for this topic's score contribution
  displayOrder  Int      @default(0)   // Order when displaying topic list
  maxItems      Int      @default(10)  // Max items to include per report

  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt    @db.Timestamptz
}

model WeeklyReport {
  id            String   @id @default(cuid())
  weekNumber    String   @unique
  editorial     String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  errorMessage  String?
  errorSteps    Json?

  picks         WeeklyPick[]
}

model WeeklyPick {
  id          String        @id @default(cuid())
  weeklyId    String
  weekly      WeeklyReport  @relation(fields: [weeklyId], references: [id], onDelete: Cascade)

  order       Int
  itemId      String?  // LEGACY: phased out, use contentId
  contentId   String?  // NEW: unified pick target (additive for migration)
  reason      String
  createdAt   DateTime      @default(now()) @db.Timestamptz

  @@index([weeklyId])
}

model WeeklyReportConfig {
  id                 String   @id @default("default")

  days               Int      @default(7)

  editorialPrompt    String?
  pickReasonPrompt   String?

  pickCount          Int      @default(6)

  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz
}

model Tweet {
  id               String          @id @default(cuid())
  tweetId          String          @unique
  tab              String
  text             String          @db.Text
  url              String
  expandedUrl      String?
  publishedAt      DateTime?       @db.Timestamptz
  fetchedAt        DateTime        @default(now()) @db.Timestamptz
  authorHandle     String
  authorName       String?
  authorId         String?
  conversationId   String?
  likeCount        Int             @default(0)
  replyCount       Int             @default(0)
  retweetCount     Int             @default(0)
  summary          String?         @db.Text
  bullets          String[]
  categories       String[]
  score            Float           @default(5.0)
  mediaJson        String?         @db.Text
  quotedTweetJson  String?         @db.Text
  threadJson       String?         @db.Text
  parentJson       String?         @db.Text
  articleJson      String?         @db.Text
  bookmarks        TweetBookmark[]
  createdAt        DateTime        @default(now()) @db.Timestamptz
  updatedAt        DateTime        @updatedAt @db.Timestamptz

  @@index([tab])
  @@index([fetchedAt])
  @@index([score])
  @@index([authorHandle])
  @@index([publishedAt])
}

model TweetBookmark {
  id           String   @id @default(cuid())
  tweetId      String   @unique
  bookmarkedAt DateTime @default(now()) @db.Timestamptz
  tweet        Tweet    @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@index([bookmarkedAt])
}

model XPageConfig {
  tab             String   @unique
  enabled         Boolean  @default(true)
  birdMode        String
  count           Int      @default(20)
  fetchAll        Boolean  @default(false)
  maxPages        Int?
  listsJson       String?  @db.Text
  filterPrompt    String?  @db.Text
  enrichEnabled   Boolean  @default(true)
  enrichScoring   Boolean  @default(true)
  enrichKeyPoints Boolean  @default(true)
  enrichTagging   Boolean  @default(true)
  timeWindow      String   @default("week")
  sortOrder       String   @default("ranked")
  updatedAt       DateTime @updatedAt @db.Timestamptz
}
