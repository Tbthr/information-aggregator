generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Bookmark {
  id           String   @id @default(cuid())
  itemId       String   @unique
  bookmarkedAt DateTime @default(now()) @db.Timestamptz
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model CustomView {
  id             String           @id @default(cuid())
  name           String
  icon           String
  description    String?
  createdAt      DateTime         @default(now()) @db.Timestamptz
  filterJson     String?
  updatedAt      DateTime         @db.Timestamptz
  order          Int              @default(0)
  customViewPacks CustomViewPack[]
}

model CustomViewPack {
  id         String     @id @default(cuid())
  viewId     String
  packId     String
  pack       Pack       @relation(fields: [packId], references: [id], onDelete: Cascade)
  view       CustomView @relation(fields: [viewId], references: [id], onDelete: Cascade)

  @@unique([viewId, packId])
  @@index([viewId])
}

model DailyOverview {
  id            String   @id @default(cuid())
  date          String   @unique
  dayLabel      String
  topicCount    Int      @default(0)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  errorMessage  String?
  errorSteps    Json?

  @@index([topicCount])

  topics        DigestTopic[]
}

model DigestTopic {
  id          String        @id @default(cuid())
  dailyId     String
  daily       DailyOverview @relation(fields: [dailyId], references: [id], onDelete: Cascade)

  order       Int
  title       String
  summary     String
  itemIds     String[]
  tweetIds    String[]
  createdAt   DateTime      @default(now()) @db.Timestamptz

  @@index([dailyId])
}

model DailyReportConfig {
  id                 String   @id @default("default")

  packs              String[]
  maxItems           Int      @default(50)
  minScore           Int      @default(0)

  keywordBlacklist   String[]
  filterPrompt       String?
  topicPrompt        String?
  topicSummaryPrompt String?
  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz
}

model Item {
  id           String   @id @default(cuid())
  title        String
  url          String
  sourceId     String
  sourceName   String
  sourceType   String
  publishedAt  DateTime?              @db.Timestamptz
  fetchedAt    DateTime @default(now()) @db.Timestamptz
  author       String?
  summary      String?  @db.Text
  bullets      String[]
  content      String?  @db.Text
  imageUrl     String?
  categories   String[]
  score        Float    @default(5.0)
  metadataJson String?  @db.Text

  source       Source        @relation(fields: [sourceId], references: [id])
  bookmarks    Bookmark[]

  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt    @db.Timestamptz

  @@unique([url])
  @@index([sourceId])
  @@index([fetchedAt])
  @@index([score])
  @@index([publishedAt])
}

model Pack {
  id          String   @id @default(cuid())
  name        String
  description String?

  sources     Source[]
  customViews CustomViewPack[]

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt    @db.Timestamptz
}

model Source {
  id          String   @id @default(cuid())
  type        String
  name        String
  url         String
  description String?
  enabled     Boolean  @default(true)
  configJson  String?  @db.Text
  packId      String?

  pack        Pack?    @relation(fields: [packId], references: [id])
  items       Item[]
  health      SourceHealth?

  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt    @db.Timestamptz

  @@unique([packId, url])
  @@index([packId])
}

model SourceHealth {
  id                  String    @id @default(cuid())
  sourceId            String    @unique
  lastSuccessAt       DateTime? @db.Timestamptz
  lastFailureAt       DateTime? @db.Timestamptz
  lastError           String?
  consecutiveFailures Int       @default(0)
  updatedAt           DateTime  @db.Timestamptz
  source              Source    @relation(fields: [sourceId], references: [id])
}

model WeeklyReport {
  id            String   @id @default(cuid())
  weekNumber    String   @unique
  editorial     String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  errorMessage  String?
  errorSteps    Json?

  picks         WeeklyPick[]
}

model WeeklyPick {
  id          String        @id @default(cuid())
  weeklyId    String
  weekly      WeeklyReport  @relation(fields: [weeklyId], references: [id], onDelete: Cascade)

  order       Int
  itemId      String
  reason      String
  createdAt   DateTime      @default(now()) @db.Timestamptz

  @@index([weeklyId])
}

model WeeklyReportConfig {
  id                 String   @id @default("default")

  days               Int      @default(7)

  editorialPrompt    String?
  pickReasonPrompt   String?

  pickCount          Int      @default(6)

  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz
}

model Tweet {
  id               String          @id @default(cuid())
  tweetId          String          @unique
  tab              String
  text             String          @db.Text
  url              String
  expandedUrl      String?
  publishedAt      DateTime?       @db.Timestamptz
  fetchedAt        DateTime        @default(now()) @db.Timestamptz
  authorHandle     String
  authorName       String?
  authorId         String?
  conversationId   String?
  likeCount        Int             @default(0)
  replyCount       Int             @default(0)
  retweetCount     Int             @default(0)
  summary          String?         @db.Text
  bullets          String[]
  categories       String[]
  score            Float           @default(5.0)
  mediaJson        String?         @db.Text
  quotedTweetJson  String?         @db.Text
  threadJson       String?         @db.Text
  parentJson       String?         @db.Text
  articleJson      String?         @db.Text
  bookmarks        TweetBookmark[]
  createdAt        DateTime        @default(now()) @db.Timestamptz
  updatedAt        DateTime        @updatedAt @db.Timestamptz

  @@index([tab])
  @@index([fetchedAt])
  @@index([score])
  @@index([authorHandle])
  @@index([publishedAt])
}

model TweetBookmark {
  id           String   @id @default(cuid())
  tweetId      String   @unique
  bookmarkedAt DateTime @default(now()) @db.Timestamptz
  tweet        Tweet    @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@index([bookmarkedAt])
}

model XPageConfig {
  tab             String   @unique
  enabled         Boolean  @default(true)
  birdMode        String
  count           Int      @default(20)
  fetchAll        Boolean  @default(false)
  maxPages        Int?
  listsJson       String?  @db.Text
  filterPrompt    String?  @db.Text
  enrichEnabled   Boolean  @default(true)
  enrichScoring   Boolean  @default(true)
  enrichKeyPoints Boolean  @default(true)
  enrichTagging   Boolean  @default(true)
  timeWindow      String   @default("week")
  sortOrder       String   @default("ranked")
  updatedAt       DateTime @updatedAt @db.Timestamptz
}
